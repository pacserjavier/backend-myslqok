<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Principal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
    <h1 class="mb-4">Bienvenido, <%= usuario.nombre %></h1>

    <div class="row">
      <!-- Botón para ir a productos -->
      <div class="col-md-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Gestión de Productos</h5>
            <p class="card-text">Accede al listado, agrega, edita o elimina productos.</p>
            <a href="/productos" class="btn btn-primary">Ir a Productos</a>
          </div>
        </div>
      </div>

      <!-- Botón para cerrar sesión -->
      <div class="col-md-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Cerrar Sesión</h5>
            <p class="card-text">Finaliza tu sesión de usuario.</p>
            <a href="/logout" class="btn btn-danger">Cerrar Sesión</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
  // Evita que el navegador muestre el dashboard desde caché
  window.addEventListener("pageshow", function(event) {
    if (event.persisted) {
      window.location.reload();
    }
  });
</script>
</body>
</html>

